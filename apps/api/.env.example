# Garden Solutions API Environment Variables
# Copy to .env and update values for your environment

# Environment: "development" or "production"
ENVIRONMENT=development

# Database
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5433
POSTGRES_DB=garden_solutions

# Auth - IMPORTANT: Change SECRET_KEY in production!
# WARNING: The default key is INSECURE and only for local development
SECRET_KEY=INSECURE_DEV_SECRET_KEY_CHANGE_IN_PROD
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Schema version for offline sync compatibility
SCHEMA_VERSION=1

# Shopify Integration (Pot Shack)
# Required for Shopify product/order sync and webhooks
SHOPIFY_SHOP_DOMAIN=pot-shack.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxx
SHOPIFY_WEBHOOK_SECRET=whsec_xxxxx
SHOPIFY_API_VERSION=2024-01
